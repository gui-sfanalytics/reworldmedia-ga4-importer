# GA4 to BigQuery Data Pipeline - Environment Variables
# Copy this file to .env and fill in your actual values.

# =============================================================================
# GCP PROJECT CONFIGURATION
# =============================================================================
# The project where data will be stored
CLIENT_PROJECT_ID=kang-all-brand

# The BigQuery dataset for GA4 data
CLIENT_DATASET_ID=poc_ga4_export

# BigQuery Credentials: 
# - Set to a secret name in Secret Manager (e.g., BIGQUERY_CREDS_SECRET_NAME)
# - OR set to a local JSON file path (e.g., service-account-key.json)
CLIENT_BIGQUERY_CREDS=kang-all-brand-ab0765007851.json

# =============================================================================
# SERVICE CONFIGURATION
# =============================================================================
# The project hosting the service (Cloud Functions, etc.)
SERVICE_PROJECT_ID=kang-all-brand

# The project where Secret Manager secrets are stored
SERVICE_SECRET_PROJECT_ID=kang-all-brand

# =============================================================================
# GOOGLE ANALYTICS 4 CONFIGURATION
# =============================================================================
# Comma-separated list of GA4 property IDs
PROPERTY_IDS=288233728

# Authentication Method (Preferred): Local Service Account Path
# Placing the JSON file in the project root is recommended for local development.
GA4_SERVICE_ACCOUNT_PATH=kang-all-brand-9d2c06fcb379.json

# Authentication Method (Legacy): OAuth Client Credentials
# These will be used ONLY if GA4_SERVICE_ACCOUNT_PATH is not set.
GA4_CLIENT_ID=
GA4_CLIENT_SECRET=
GA4_REFRESH_TOKEN=

# =============================================================================
# PUB/SUB CONFIGURATION
# =============================================================================
SERVICE_GA4_TO_REPORT_TOPIC=ga4topic
SERVICE_SLACK_MESSAGE_TOPIC=ga4topic

# =============================================================================
# ADDITIONAL CONFIGURATION
# =============================================================================
# Set to true for more detailed logging
LOG_EXECUTION_ID=false
